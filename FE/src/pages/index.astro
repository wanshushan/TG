---
import BaseHead from "../components/BaseHead.astro";
import Footer from "../components/Footer.astro";
import Header from "../components/Header.astro";
import HomeContent from "../content/index/index.mdx";
import { getMarkdownRenderConfig, siteConfig } from "../config";

const markdownContentDesktopWidth =
    getMarkdownRenderConfig().desktopContentWidth;
const markdownFontScale = getMarkdownRenderConfig().fontScale;
---

<!doctype html>
<html lang={siteConfig.defaultLanguage} data-overlayscrollbars-initialize>
    <head>
        <BaseHead
            title={siteConfig.title}
            description={siteConfig.description}
        />
        <style>
            main {
                width: calc(100% - 2em);
                max-width: 100%;
                display: flex;
                justify-content: center;
                align-items: center;
                text-align: center;
                min-height: 60vh;
            }

            .home-content {
                max-width: 720px;
                font-size: var(--markdown-font-scale);
                overflow-wrap: anywhere;
                word-break: break-word;
            }

            .home-content :where(p, li, a, span, h1, h2, h3, h4, h5, h6) {
                overflow-wrap: anywhere;
                word-break: break-word;
            }

            :global(.home-content h2 a),
            :global(.home-content h3 a) {
                color: rgb(var(--black));
                font-weight: 700;
                text-decoration: none;
                transition: color 0.2s ease;
            }

            :global(.home-content h2 a:hover),
            :global(.home-content h3 a:hover) {
                color: var(--accent);
            }

            @media (min-width: 721px) {
                .home-content {
                    width: var(--markdown-content-desktop-width);
                    max-width: var(--markdown-content-desktop-width);
                }
            }
        </style>
    </head>
    <body>
        <Header />
        <main>
            <div
                class="home-content"
                style={`--markdown-content-desktop-width: ${markdownContentDesktopWidth}; --markdown-font-scale: ${markdownFontScale};`}
            >
                <HomeContent />
            </div>
        </main>
        <Footer />
    </body>
</html>
