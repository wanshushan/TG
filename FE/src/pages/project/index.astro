            function updateBubbleContent(
                bubble: HTMLDivElement | null,
                text: string,
            ) {
                if (!bubble) {
                    return;
                }
                bubble.innerHTML = renderMarkdownToHtml(text);
                if (messagesEl) {
                    messagesEl.scrollTop = messagesEl.scrollHeight;
                }
            }

            async function readPlainTextStream(
                response: Response,
                bubble: HTMLDivElement | null,
            ): Promise<string> {
                if (!response.body) {
                    const text = await response.text();
                    updateBubbleContent(bubble, text);
                    return text;
                }

                const reader = response.body.getReader();
                const decoder = new TextDecoder();
                let fullText = "";

                while (true) {
                    const { done, value } = await reader.read();
                    if (done) {
                        break;
                    }
                    if (!value) {
                        continue;
                    }
                    const chunkText = decoder.decode(value, { stream: true });
                    if (!chunkText) {
                        continue;
                    }
                    fullText += chunkText;
                    updateBubbleContent(bubble, fullText);
                }

                const tail = decoder.decode();
                if (tail) {
                    fullText += tail;
                    updateBubbleContent(bubble, fullText);
                }

                return fullText;
            }

