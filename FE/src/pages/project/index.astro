---
import BaseHead from "../../components/BaseHead.astro";
import Header from "../../components/Header.astro";
import { siteConfig } from "../../config";
---

<!doctype html>
<html lang={siteConfig.defaultLanguage} data-overlayscrollbars-initialize>
    <head>
        <BaseHead title="灵诊·问诊" description="AI 对话项目页" />
        <style>
            :global(html) {
                scrollbar-width: thin;
                scrollbar-color: rgba(var(--gray), 0.65)
                    rgba(var(--gray-light), 0.6);
            }
            :global(html::-webkit-scrollbar),
            :global(body::-webkit-scrollbar),
            .messages::-webkit-scrollbar {
                width: 6px;
                height: 6px;
            }
            :global(html::-webkit-scrollbar-track),
            :global(body::-webkit-scrollbar-track),
            .messages::-webkit-scrollbar-track {
                background: rgba(var(--gray-light), 0.6);
            }
            :global(html::-webkit-scrollbar-thumb),
            :global(body::-webkit-scrollbar-thumb),
            .messages::-webkit-scrollbar-thumb {
                background: rgba(var(--gray), 0.65);
                border-radius: 999px;
            }
            :global(html::-webkit-scrollbar-thumb:hover),
            :global(body::-webkit-scrollbar-thumb:hover),
            .messages::-webkit-scrollbar-thumb:hover {
                background: rgba(var(--gray), 0.85);
            }
            :global(body) {
                min-height: 100vh;
                display: flex;
                flex-direction: column;
            }
            main.chat-page {
                width: 100%;
                max-width: none;
                margin: 0;
                padding: 0.8rem 0;
                flex: 1;
                min-height: 0;
                display: flex;
                --chat-radius: 0.95rem;
                --chat-radius-sm: 0.8rem;
            }
            .chat-shell {
                flex: 1;
                width: calc(100% - 10px);
                margin: 0 auto;
                min-height: 0;
                border: 1px solid rgba(var(--gray), 0.35);
                border-radius: var(--chat-radius);
                background: white;
                display: grid;
                grid-template-rows: auto minmax(0, 1fr) auto;
                overflow: hidden;
            }
            .chat-topbar {
                display: flex;
                justify-content: space-between;
                align-items: flex-start;
                gap: 1rem;
                padding: 1rem 1.1rem;
                border-bottom: 1px solid rgba(var(--gray), 0.35);
                background: rgba(var(--gray-light), 0.75);
            }
            .topbar-left {
                display: grid;
                grid-template-rows: 2.4rem auto;
                align-items: center;
                justify-items: start;
                row-gap: 0.35rem;
            }
            .topbar-right {
                display: grid;
                grid-template-rows: 2.4rem auto;
                align-items: center;
                justify-items: end;
                row-gap: 0.35rem;
                justify-content: flex-start;
            }
            .stream-toggle {
                display: inline-flex;
                align-items: center;
                gap: 0.35rem;
                padding: 0.25rem 0.55rem;
                border-radius: 999px;
                border: 1px solid rgba(var(--gray), 0.45);
                background: white;
                font-size: 0.8rem;
                color: rgba(var(--gray-dark), 0.85);
            }
            .temp-control {
                display: inline-flex;
                align-items: center;
                gap: 0.4rem;
                padding: 0.2rem 0.55rem;
                border-radius: 999px;
                border: 1px solid rgba(var(--gray), 0.45);
                background: white;
                font-size: 0.8rem;
                color: rgba(var(--gray-dark), 0.85);
            }
            .temp-control input {
                width: 4rem;
                border: 0;
                background: transparent;
                color: rgb(var(--gray-dark));
                font-size: 0.82rem;
                line-height: 1.2;
            }
            .temp-control input:focus {
                outline: none;
            }
            .chat-topbar h1 {
                margin: 0;
                font-size: 1.35rem;
                line-height: 1.25;
            }
            .subtitle {
                margin: 0.3rem 0 0;
                font-size: 0.95rem;
                color: rgba(var(--gray-dark), 0.82);
            }
            .status {
                margin: 0;
                padding: 0.35rem 0.75rem;
                border-radius: 999px;
                border: 1px solid rgba(var(--accent-rgb), 0.35);
                background: rgba(var(--accent-rgb), 0.12);
                font-size: 0.8rem;
                line-height: 1.25;
                color: var(--accent-dark);
                white-space: nowrap;
            }
            .messages {
                min-height: 0;
                overflow-y: auto;
                padding: 1rem;
                background: rgba(var(--gray-light), 0.45);
            }
            .empty-state {
                margin: 16vh auto 0;
                max-width: 500px;
                text-align: center;
                border: 1px dashed rgba(var(--gray), 0.5);
                border-radius: var(--chat-radius);
                padding: 1rem 1.2rem;
                background: rgb(var(--gray-light));
            }
            .empty-state h2 {
                margin: 0 0 0.35rem;
                font-size: 1.15rem;
            }
            .empty-state p {
                margin: 0;
                font-size: 0.95rem;
                color: rgba(var(--gray-dark), 0.82);
            }
            :global(.message-row) {
                display: flex;
                align-items: flex-start;
                gap: 0.6rem;
                width: calc(100% - 20px);
                margin: 0 auto 0.85rem;
            }
            :global(.message-row.user) {
                flex-direction: row-reverse;
            }
            :global(.avatar) {
                width: 1.95rem;
                height: 1.95rem;
                border-radius: 999px;
                border: 1px solid rgba(var(--gray), 0.45);
                background: rgb(var(--gray-light));
                color: rgb(var(--gray-dark));
                font-size: 0.72rem;
                font-weight: 700;
                display: flex;
                align-items: center;
                justify-content: center;
                flex-shrink: 0;
            }
            :global(.message-row.user .avatar) {
                background: rgba(var(--accent-rgb), 0.15);
                border-color: rgba(var(--accent-rgb), 0.35);
                color: rgb(var(--accent-dark));
            }
            :global(.bubble) {
                max-width: min(74%, 720px);
                padding: 0.78rem 1rem;
                border-radius: 1.08rem;
                border: 1px solid rgba(var(--gray), 0.46);
                background: white;
                color: rgb(var(--gray-dark));
                font-size: 0.95rem;
                line-height: 1.55;
                word-break: break-word;
            }
            :global(.message-row.ai .bubble) {
                border-top-left-radius: 0.52rem;
            }
            :global(.bubble)
                :where(h1, h2, h3, h4, h5, h6, p, ul, ol, blockquote, pre) {
                margin: 0 0 0.72rem;
            }
            :global(.bubble) :where(h1, h2, h3, h4, h5, h6) {
                line-height: 1.35;
            }
            :global(.bubble)
                :where(
                    p:last-child,
                    ul:last-child,
                    ol:last-child,
                    blockquote:last-child,
                    pre:last-child
                ) {
                margin-bottom: 0;
            }
            :global(.bubble) :where(ul, ol) {
                padding-left: 1.2rem;
            }
            :global(.bubble) :where(pre) {
                padding: 0.68rem 0.75rem;
                overflow-x: auto;
                border-radius: 0.62rem;
                border: 1px solid rgba(var(--gray), 0.35);
                background: rgba(var(--gray-light), 0.75);
            }
            :global(.bubble) :where(code) {
                padding: 0.1rem 0.35rem;
                border-radius: 0.4rem;
                background: rgba(var(--gray-light), 0.85);
            }
            :global(.bubble) :where(pre code) {
                padding: 0;
                border-radius: 0;
                background: transparent;
            }
            :global(.bubble) :where(a) {
                color: var(--accent-dark);
                text-decoration: underline;
            }
            :global(.message-row.user .bubble) {
                background: var(--accent);
                border-color: var(--accent-dark);
                color: white;
                border-radius: 1.08rem;
                border-top-right-radius: 0.52rem;
            }
            :global(.message-row.user .bubble) :where(a) {
                color: white;
            }
            :global(.message-row.user .bubble) :where(code) {
                background: rgba(255, 255, 255, 0.18);
                color: white;
            }
            :global(.message-row.user .bubble) :where(pre) {
                border-color: rgba(255, 255, 255, 0.3);
                background: rgba(0, 0, 0, 0.16);
            }
            .chat-form {
                display: flex;
                align-items: flex-end;
                gap: 0.7rem;
                padding: 0.85rem 1rem 1rem;
                border-top: 1px solid rgba(var(--gray), 0.35);
                background: rgba(var(--gray-light), 0.75);
            }
            .chat-form textarea {
                flex: 1;
                margin: 0;
                min-height: 2.9rem;
                max-height: 10rem;
                box-sizing: border-box;
                padding: 0.72rem 0.8rem;
                border: 1px solid rgba(var(--gray), 0.56);
                border-radius: var(--chat-radius-sm);
                background: white;
                color: rgb(var(--gray-dark));
                font-size: 0.95rem;
                line-height: 1.45;
                resize: none;
                overflow-y: auto;
                overscroll-behavior: contain;
                scroll-behavior: smooth;
                -webkit-overflow-scrolling: touch;
                scrollbar-width: thin;
                scrollbar-color: rgba(var(--gray), 0.6)
                    rgba(var(--gray-light), 0.55);
            }
            .chat-form textarea::-webkit-scrollbar {
                width: 6px;
            }
            .chat-form textarea::-webkit-scrollbar-track {
                background: rgba(var(--gray-light), 0.55);
                border-radius: 999px;
            }
            .chat-form textarea::-webkit-scrollbar-thumb {
                background: rgba(var(--gray), 0.6);
                border-radius: 999px;
            }
            .chat-form textarea::-webkit-scrollbar-thumb:hover {
                background: rgba(var(--gray), 0.8);
            }
            .chat-form textarea:focus {
                outline: 2px solid rgba(var(--accent-rgb), 0.3);
                border-color: rgba(var(--accent-rgb), 0.45);
            }
            .chat-form button {
                height: 2.9rem;
                padding: 0 1rem;
                border: 1px solid var(--accent-dark);
                border-radius: var(--chat-radius-sm);
                background: var(--accent-dark);
                color: white;
                font-size: 0.95rem;
                cursor: pointer;
            }
            .chat-form button:disabled {
                opacity: 0.55;
                cursor: not-allowed;
            }
            .chat-form-actions {
                display: inline-flex;
                flex-direction: column;
                align-items: stretch;
                gap: 0.45rem;
                width: 21rem;
                flex-shrink: 0;
            }
            .attachment-row {
                display: flex;
                align-items: stretch;
                gap: 0.45rem;
            }
            .attachment-row .attachment-picker {
                flex: 1;
                min-width: 0;
            }
            .attachment-picker {
                display: inline-flex;
                align-items: center;
                gap: 0.45rem;
                padding: 0.2rem 0.35rem;
                border-radius: var(--chat-radius-sm);
                border: 1px solid rgba(var(--gray), 0.45);
                background: white;
            }
            .attachment-picker > span {
                font-size: 0.78rem;
                line-height: 1;
                color: rgba(var(--gray-dark), 0.8);
            }
            .attachment-picker .picker-trigger {
                min-width: 0;
                width: 100%;
                max-width: none;
                color: white;
            }
            .attachment-picker .picker-trigger-label {
                color: white;
                overflow: hidden;
                text-overflow: ellipsis;
                white-space: nowrap;
            }
            .attachment-picker .picker-trigger-icon {
                color: white;
                fill: currentColor;
            }
            .attachment-picker .picker-panel {
                left: 0;
                right: 0;
                top: auto;
                bottom: calc(100% + 0.4rem);
                width: auto;
                max-width: none;
            }
            .chat-shell,
            .chat-topbar,
            .history-picker,
            .model-picker,
            .attachment-picker,
            .stream-toggle,
            .temp-control,
            .status,
            .empty-state,
            :global(.avatar),
            :global(.bubble),
            :global(.bubble) :where(pre),
            .chat-form,
            .chat-form textarea,
            .chat-form button {
                border: none !important;
            }
            .chat-form textarea:focus {
                outline: none !important;
            }
            @media (max-width: 720px) {
                main.chat-page {
                    width: 100%;
                    min-height: 0;
                    padding: 0.55rem 0;
                    --chat-radius: 0.85rem;
                    --chat-radius-sm: 0.75rem;
                }
                .chat-shell {
                    border-radius: var(--chat-radius);
                }
                .chat-topbar {
                    flex-direction: column;
                    align-items: flex-start;
                    gap: 0.55rem;
                }
                .topbar-right {
                    width: 100%;
                    justify-content: flex-start;
                    justify-items: start;
                }
                .topbar-left {
                    width: 100%;
                }
                .history-picker,
                .model-picker {
                    width: 100%;
                    max-width: 100%;
                    box-sizing: border-box;
                }
                .picker-trigger {
                    flex: 1;
                    min-width: 0;
                    max-width: 100%;
                }
                .picker-panel {
                    left: 0;
                    right: 0;
                    width: auto;
                    max-width: 100%;
                }
                .status {
                    white-space: normal;
                }
                :global(.bubble) {
                    max-width: 90%;
                }
                .chat-form {
                    padding: 0.75rem;
                    flex-direction: column;
                    align-items: stretch;
                }
                .chat-form-actions {
                    width: 100%;
                }
                .chat-form button {
                    width: 100%;
                }
            }
        </style>
    </head>
    <body>
        <Header />
        <main class="chat-page">
            <section class="chat-shell">
                <div class="chat-topbar">
                    <div class="topbar-left">
                        <h1>灵诊·问诊</h1>
                        <label
                            class="history-picker picker-more"
                            for="history-select"
                            id="history-picker-root"
                        >
                            <span>问诊记录</span>
                            <select
                                id="history-select"
                                class="picker-native"
                                aria-label="选择问诊记录"></select>
                            <button
                                id="history-picker-trigger"
                                class="picker-trigger"
                                type="button"
                                aria-haspopup="listbox"
                                aria-expanded="false"
                                aria-controls="history-picker-panel"
                            >
                                <span
                                    id="history-picker-label"
                                    class="picker-trigger-label">当前会话</span
                                >
                                <svg
                                    class="picker-trigger-icon"
                                    viewBox="0 0 24 24"
                                    width="14"
                                    height="14"
                                    aria-hidden="true"
                                >
                                    <path d="M7 10l5 5 5-5z"></path>
                                </svg>
                            </button>
                            <div
                                id="history-picker-panel"
                                class="picker-panel"
                                role="listbox"
                                aria-label="问诊记录选项"
                            >
                                <div
                                    id="history-picker-options"
                                    class="picker-options"
                                >
                                </div>
                            </div>
                        </label>
                    </div>
                    <div class="topbar-right">
                        <div id="status" class="status">
                            正在读取 API 配置...
                        </div>
                        <label
                            class="model-picker picker-more"
                            for="model-select"
                            id="model-picker-root"
                        >
                            <span>模型/API</span>
                            <select
                                id="model-select"
                                class="picker-native"
                                aria-label="选择模型"></select>
                            <button
                                id="model-picker-trigger"
                                class="picker-trigger"
                                type="button"
                                aria-haspopup="listbox"
                                aria-expanded="false"
                                aria-controls="model-picker-panel"
                            >
                                <span
                                    id="model-picker-label"
                                    class="picker-trigger-label">未选择</span
                                >
                                <svg
                                    class="picker-trigger-icon"
                                    viewBox="0 0 24 24"
                                    width="14"
                                    height="14"
                                    aria-hidden="true"
                                >
                                    <path d="M7 10l5 5 5-5z"></path>
                                </svg>
                            </button>
                            <div
                                id="model-picker-panel"
                                class="picker-panel"
                                role="listbox"
                                aria-label="模型选项"
                            >
                                <div
                                    id="model-picker-options"
                                    class="picker-options"
                                >
                                </div>
                            </div>
                        </label>
                        <!-- 流式开关前端显示 -->
                        <!-- <label class="stream-toggle" for="stream-toggle">
                            <input
                                id="stream-toggle"
                                type="checkbox"
                                aria-label="是否流式输出"
                            />
                            流式
                        </label>  -->
                        <!-- 温度控制前端开关 -->
                        <!-- <label class="temp-control" for="temperature-input">
                            <span>温度</span>
                            <input
                                id="temperature-input"
                                type="number"
                                min="0"
                                max="2"
                                step="0.1"
                                aria-label="temperature"
                            />
                        </label>  -->
                    </div>
                </div>
                <section id="messages" class="messages" aria-live="polite">
                    <div id="empty-state" class="empty-state">
                        <h2>新问诊</h2>
                        <p>-输入问题开始吧-</p>
                        <p>（提示：如果需要使用面诊或舌诊数据，请先选择对应的附件）</p>
                        <p>你可以描述症状，也可以上传附件分析身体情况</p>
                    </div>
                </section>
                <form id="chat-form" class="chat-form">
                    <textarea
                        id="user-input"
                        rows="1"
                        placeholder="Enter 发送 , Shift+Enter 换行 , 选择附件以使用面部与舌头数据（可选）"
                        required></textarea>
                    <div class="chat-form-actions">
                        <div class="attachment-row">
                            <label
                                class="attachment-picker picker-more"
                                for="attachment-face-select"
                                id="attachment-face-picker-root"
                            >
                                <span>面诊附件</span>
                                <select
                                    id="attachment-face-select"
                                    class="picker-native"
                                    aria-label="选择面诊附件"></select>
                                <button
                                    id="attachment-face-picker-trigger"
                                    class="picker-trigger"
                                    type="button"
                                    aria-haspopup="listbox"
                                    aria-expanded="false"
                                    aria-controls="attachment-face-picker-panel"
                                >
                                    <span
                                        id="attachment-face-picker-label"
                                        class="picker-trigger-label"
                                        >不附加</span
                                    >
                                    <svg
                                        xmlns="http://www.w3.org/2000/svg"
                                        width="18"
                                        height="22"
                                        viewBox="0 0 448 512"
                                        ><!-- Icon from Font Awesome 6 Regular by Dave Gandy - https://creativecommons.org/licenses/by/4.0/ -->
                                        <path
                                            fill="currentColor"
                                            d="M384 336H192c-8.8 0-16-7.2-16-16V64c0-8.8 7.2-16 16-16h140.1l67.9 67.9V320c0 8.8-7.2 16-16 16m-192 48h192c35.3 0 64-28.7 64-64V115.9c0-12.7-5.1-24.9-14.1-33.9l-67.8-67.9c-9-9-21.2-14.1-33.9-14.1H192c-35.3 0-64 28.7-64 64v256c0 35.3 28.7 64 64 64M64 128c-35.3 0-64 28.7-64 64v256c0 35.3 28.7 64 64 64h192c35.3 0 64-28.7 64-64v-32h-48v32c0 8.8-7.2 16-16 16H64c-8.8 0-16-7.2-16-16V192c0-8.8 7.2-16 16-16h32v-48z"
                                        ></path></svg
                                    >
                                </button>
                                <div
                                    id="attachment-face-picker-panel"
                                    class="picker-panel"
                                    role="listbox"
                                    aria-label="面诊附件选项"
                                >
                                    <div
                                        id="attachment-face-picker-options"
                                        class="picker-options"
                                    >
                                    </div>
                                </div>
                            </label>
                            <label
                                class="attachment-picker picker-more"
                                for="attachment-tg-select"
                                id="attachment-tg-picker-root"
                            >
                                <span>舌诊附件</span>
                                <select
                                    id="attachment-tg-select"
                                    class="picker-native"
                                    aria-label="选择舌诊附件"></select>
                                <button
                                    id="attachment-tg-picker-trigger"
                                    class="picker-trigger"
                                    type="button"
                                    aria-haspopup="listbox"
                                    aria-expanded="false"
                                    aria-controls="attachment-tg-picker-panel"
                                >
                                    <span
                                        id="attachment-tg-picker-label"
                                        class="picker-trigger-label"
                                        >不附加</span
                                    >
                                    <svg
                                        xmlns="http://www.w3.org/2000/svg"
                                        width="18"
                                        height="22"
                                        viewBox="0 0 448 512"
                                        ><!-- Icon from Font Awesome 6 Regular by Dave Gandy - https://creativecommons.org/licenses/by/4.0/ -->
                                        <path
                                            fill="currentColor"
                                            d="M384 336H192c-8.8 0-16-7.2-16-16V64c0-8.8 7.2-16 16-16h140.1l67.9 67.9V320c0 8.8-7.2 16-16 16m-192 48h192c35.3 0 64-28.7 64-64V115.9c0-12.7-5.1-24.9-14.1-33.9l-67.8-67.9c-9-9-21.2-14.1-33.9-14.1H192c-35.3 0-64 28.7-64 64v256c0 35.3 28.7 64 64 64M64 128c-35.3 0-64 28.7-64 64v256c0 35.3 28.7 64 64 64h192c35.3 0 64-28.7 64-64v-32h-48v32c0 8.8-7.2 16-16 16H64c-8.8 0-16-7.2-16-16V192c0-8.8 7.2-16 16-16h32v-48z"
                                        ></path></svg
                                    >
                                </button>
                                <div
                                    id="attachment-tg-picker-panel"
                                    class="picker-panel"
                                    role="listbox"
                                    aria-label="舌诊附件选项"
                                >
                                    <div
                                        id="attachment-tg-picker-options"
                                        class="picker-options"
                                    >
                                    </div>
                                </div>
                            </label>
                        </div>
                        <button id="send-btn" type="submit">发送</button>
                    </div>
                </form>
            </section>
        </main>

        <script>
            import { marked } from "marked";
            import DOMPurify from "dompurify";

            const statusEl = document.querySelector(
                "#status",
            ) as HTMLDivElement | null;
            const messagesEl = document.querySelector(
                "#messages",
            ) as HTMLElement | null;
            const emptyStateEl = document.querySelector(
                "#empty-state",
            ) as HTMLDivElement | null;
            const formEl = document.querySelector(
                "#chat-form",
            ) as HTMLFormElement | null;
            const chatFormActionsEl = document.querySelector(
                ".chat-form-actions",
            ) as HTMLDivElement | null;
            const inputEl = document.querySelector(
                "#user-input",
            ) as HTMLTextAreaElement | null;
            const sendBtn = document.querySelector(
                "#send-btn",
            ) as HTMLButtonElement | null;
            const modelSelectEl = document.querySelector(
                "#model-select",
            ) as HTMLSelectElement | null;
            const historySelectEl = document.querySelector(
                "#history-select",
            ) as HTMLSelectElement | null;
            const historyPickerRootEl = document.querySelector(
