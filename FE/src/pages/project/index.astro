            async function loadRecordByName(recordName: string) {
                const response = await fetch(
                    `${chatProxyUrl}?action=load&name=${encodeURIComponent(recordName)}`,
                    {
                        cache: "no-store",
                        credentials: "include",
                    },
                );
                if (!response.ok) {
                    const detail = (await response.text()).trim();
                    throw new Error(
                        `读取记录失败：HTTP ${response.status}${detail ? ` - ${detail}` : ""}`,
                    );
                }

                const payload = (await response.json()) as {
                    recordName?: unknown;
                    messages?: unknown;
                };

                const loadedMessages = normalizeRecordMessages(
                    payload.messages,
                );
                const loadedRecordName =
                    typeof payload.recordName === "string"
                        ? payload.recordName.trim()
                        : recordName;

                chatHistory.splice(0, chatHistory.length, ...loadedMessages);
                currentRecordName = loadedRecordName;
                if (
                    currentRecordName &&
                    !recordNames.includes(currentRecordName)
                ) {
                    recordNames = sortRecordNames([
                        currentRecordName,
                        ...recordNames,
                    ]);
                }
                renderHistoryOptions();
                renderConversation(chatHistory);
            }

            async function saveConversationRecord(): Promise<string> {
                if (chatHistory.length === 0) {
                    return "";
                }

                const response = await fetch(chatProxyUrl, {
                    method: "PUT",
                    headers: {
                        "Content-Type": "application/json",
                    },
                    credentials: "include",
                    body: JSON.stringify({
                        recordName: currentRecordName || undefined,
                        messages: chatHistory,
                    }),
                });

                if (!response.ok) {
                    const detail = (await response.text()).trim();
                    throw new Error(
                        `保存记录失败：HTTP ${response.status}${detail ? ` - ${detail}` : ""}`,
                    );
                }

                const payload = (await response.json()) as {
                    recordName?: unknown;
                    records?: unknown;
                };

                const savedRecordName =
                    typeof payload.recordName === "string"
                        ? payload.recordName.trim()
                        : "";
                if (savedRecordName) {
                    currentRecordName = savedRecordName;
                }

                const recordsFromServer = Array.isArray(payload.records)
                    ? payload.records
                          .filter(
                              (value): value is string =>
                                  typeof value === "string",
                          )
                          .map((value) => value.trim())
                          .filter((value) => value.length > 0)
                    : [];

                if (recordsFromServer.length > 0) {
                    recordNames = sortRecordNames(recordsFromServer);
                } else if (
                    currentRecordName &&
                    !recordNames.includes(currentRecordName)
                ) {
                    recordNames = sortRecordNames([
                        currentRecordName,
                        ...recordNames,
                    ]);
                }
                renderHistoryOptions();

                return currentRecordName;
            }

            function parseReply(payload: unknown): string {
                if (typeof payload === "string") {
                    return payload;
                }
                if (payload && typeof payload === "object") {
                    const data = payload as {
                        reply?: unknown;
                        message?: unknown;
                        choices?: Array<{
                            message?: { content?: unknown };
                            text?: unknown;
                        }>;
                    };
                    if (typeof data.reply === "string") {
                        return data.reply;
                    }
                    if (typeof data.message === "string") {
                        return data.message;
                    }
                    if (
                        data.message &&
                        typeof data.message === "object" &&
                        typeof (data.message as { content?: unknown })
                            .content === "string"
                    ) {
                        return (data.message as { content: string }).content;
                    }
                    const content = data.choices?.[0]?.message?.content;
                    if (typeof content === "string") {
                        return content;
                    }
                    const text = data.choices?.[0]?.text;
                    if (typeof text === "string") {
                        return text;
                    }
                }
                try {
                    return JSON.stringify(payload);
                } catch {
                    return "收到响应，但无法解析内容。";
                }
            }

            async function loadApiConfig() {
                if (!statusEl) {
                    return;
                }
                try {
                    const response = await fetch(configUrl, {
                        cache: "no-store",
                        credentials: "include",
                    });
                    if (!response.ok) {
                        throw new Error(
                            `读取配置失败：HTTP ${response.status}`,
                        );
                    }
                    const config = (await response.json()) as {
                        apiEndpoint?: string;
                        model?: string;
                        selectedOptionName?: string;
                        stream?: boolean;
                        temperature?: number;
                        modelOptions?: Array<
                            | string
                            | {
                                  name?: string;
                                  label?: string;
                                  model?: string;
                                  apiEndpoint?: string;
                                  systemPrompt?: string;
                                  stream?: boolean;
                                  temperature?: number;
                              }
                        >;
                        systemPrompt?: string;
                    };
                    const fallbackApiEndpoint = (
                        config.apiEndpoint || ""
                    ).trim();
                    const fallbackModel = (config.model || "llama3.2").trim();
                    const fallbackSystemPrompt = (
                        config.systemPrompt || ""
                    ).trim();
                    const fallbackStream =
                        typeof config.stream === "boolean"
                            ? config.stream
                            : false;
                    const fallbackTemperature = normalizeTemperature(
                        config.temperature,
                    );

                    apiEndpoint = normalizeApiEndpoint(fallbackApiEndpoint);
                    model = fallbackModel;
                    systemPrompt = fallbackSystemPrompt;

                    modelOptions = normalizeModelOptions(
                        Array.isArray(config.modelOptions)
                            ? config.modelOptions
                            : [],
                        {
                            apiEndpoint: fallbackApiEndpoint,
                            model: fallbackModel,
                            systemPrompt: fallbackSystemPrompt,
                            stream: fallbackStream,
                            temperature: fallbackTemperature,
                        },
                    );

                    const preferredOptionName = (
                        config.selectedOptionName || ""
                    ).trim();
                    const matchedOptionName = modelOptions.find(
                        (option) =>
                            option.model === fallbackModel &&
                            option.apiEndpoint === fallbackApiEndpoint,
                    )?.name;

                    selectedOptionName =
                        modelOptions.find(
                            (option) => option.name === preferredOptionName,
                        )?.name ||
                        matchedOptionName ||
                        modelOptions[0]?.name ||
                        "";

                    if (selectedOptionName) {
                        applySelectedOption(selectedOptionName);
                    }
                    renderModelOptions();

                    if (apiEndpoint) {
                        setStatus(
                            `接口已就绪（${selectedOptionName || model}）`,
                        );
                        await ensureLocalOllamaModelReady();
                    } else {
                        setStatus("请先在 api.json 中填写 apiEndpoint。");
                    }
                } catch (error) {
                    setStatus(`无法读取 api.json：${getErrorMessage(error)}`);
                }
            }

            if (statusEl && messagesEl && formEl && inputEl && sendBtn) {
                syncModelPickerMenu = setupPickerMenu({
                    rootEl: modelPickerRootEl,
                    selectEl: modelSelectEl,
                    triggerEl: modelPickerTriggerEl,
                    labelEl: modelPickerLabelEl,
                    panelEl: modelPickerPanelEl,
                    optionsEl: modelPickerOptionsEl,
                    emptyLabel: "未选择",
                });
                syncHistoryPickerMenu = setupPickerMenu({
                    rootEl: historyPickerRootEl,
                    selectEl: historySelectEl,
                    triggerEl: historyPickerTriggerEl,
                    labelEl: historyPickerLabelEl,
                    panelEl: historyPickerPanelEl,
                    optionsEl: historyPickerOptionsEl,
                    emptyLabel: "当前会话",
                });
                syncFaceAttachmentPickerMenu = setupPickerMenu({
                    rootEl: attachmentFacePickerRootEl,
                    selectEl: attachmentFaceSelectEl,
                    triggerEl: attachmentFacePickerTriggerEl,
                    labelEl: attachmentFacePickerLabelEl,
                    panelEl: attachmentFacePickerPanelEl,
                    optionsEl: attachmentFacePickerOptionsEl,
                    emptyLabel: "不附加",
                });
                syncTgAttachmentPickerMenu = setupPickerMenu({
                    rootEl: attachmentTgPickerRootEl,
                    selectEl: attachmentTgSelectEl,
                    triggerEl: attachmentTgPickerTriggerEl,
                    labelEl: attachmentTgPickerLabelEl,
                    panelEl: attachmentTgPickerPanelEl,
                    optionsEl: attachmentTgPickerOptionsEl,
                    emptyLabel: "不附加",
                });

                inputEl.addEventListener("input", autoResizeInput);
                window.addEventListener("resize", autoResizeInput);
                inputEl.addEventListener("keydown", (event) => {
                    if (event.key === "Enter" && !event.shiftKey) {
                        event.preventDefault();
                        formEl.requestSubmit();
                    }
                });
                modelSelectEl?.addEventListener("change", async () => {
                    applySelectedOption(modelSelectEl.value);
                    // 前端流式与温控显示
                    // setStatus(
                    //     `已切换：${selectedOptionName}（${model}，流式：${useStream ? "开" : "关"}，温度：${currentTemperature ?? "默认"}）`,
                    // );
                    setStatus(`已切换：${selectedOptionName}（${model}）`);
                    await ensureLocalOllamaModelReady();
                });
                streamToggleEl?.addEventListener("change", () => {
                    useStream = streamToggleEl.checked;
                    setStatus(
                        `已${useStream ? "开启" : "关闭"}流式输出（温度：${currentTemperature ?? "默认"}）`,
                    );
                });
                temperatureInputEl?.addEventListener("change", () => {
                    currentTemperature = normalizeTemperature(
                        temperatureInputEl.value,
                    );
                    if (
                        temperatureInputEl.value.trim() &&
                        currentTemperature === null
                    ) {
                        temperatureInputEl.value = "";
                    } else if (currentTemperature !== null) {
                        temperatureInputEl.value = String(currentTemperature);
                    }
                    setStatus(
                        `温度已设置为：${currentTemperature ?? "默认"}（流式：${useStream ? "开" : "关"}）`,
                    );
                });
                historySelectEl?.addEventListener("change", async () => {
                    const selectedHistory = historySelectEl.value.trim();
                    if (!selectedHistory) {
                        currentRecordName = "";
                        chatHistory.splice(0, chatHistory.length);
                        renderConversation(chatHistory);
                        setStatus("已切换到当前会话。可以开始新对话。");
                        inputEl.focus();
                        return;
                    }

                    sendBtn.disabled = true;
                    try {
                        await loadRecordByName(selectedHistory);
                        setStatus(`已加载对话记录：${selectedHistory}`);
                    } catch (error) {
                        setStatus(`加载记录失败：${getErrorMessage(error)}`);
                    } finally {
                        sendBtn.disabled = false;
                        inputEl.focus();
                    }
                });
                attachmentFaceSelectEl?.addEventListener("change", async () => {
                    const selectedAttachment =
                        attachmentFaceSelectEl.value.trim();
                    if (!selectedAttachment) {
                        selectedFaceAttachmentName = "";
                        selectedFacePrompt = "";
                        setStatus("已取消面诊附件。将仅使用问诊基础提示词。");
                        return;
                    }

                    sendBtn.disabled = true;
                    try {
                        await loadFaceAttachmentByName(selectedAttachment);
                        setStatus(`已附加面诊数据：${selectedAttachment}`);
                    } catch (error) {
                        selectedFaceAttachmentName = "";
                        selectedFacePrompt = "";
                        attachmentFaceSelectEl.value = "";
                        syncFaceAttachmentPickerMenu();
                        setStatus(`附件加载失败：${getErrorMessage(error)}`);
                    } finally {
                        sendBtn.disabled = false;
                        inputEl.focus();
                    }
                });
                attachmentFacePickerTriggerEl?.addEventListener("click", () => {
                    void (async () => {
                        try {
                            await fetchFaceAttachmentList();
                        } catch (error) {
                            setStatus(
                                `读取附件列表失败：${getErrorMessage(error)}`,
                            );
                        }
                    })();
                });
                attachmentTgSelectEl?.addEventListener("change", async () => {
                    const selectedAttachment =
                        attachmentTgSelectEl.value.trim();
                    if (!selectedAttachment) {
                        selectedTgAttachmentName = "";
                        selectedTgPrompt = "";
                        setStatus("已取消舌诊附件。将仅使用问诊基础提示词。");
                        return;
                    }

                    sendBtn.disabled = true;
                    try {
                        await loadTgAttachmentByName(selectedAttachment);
                        setStatus(`已附加舌诊数据：${selectedAttachment}`);
                    } catch (error) {
                        selectedTgAttachmentName = "";
                        selectedTgPrompt = "";
                        attachmentTgSelectEl.value = "";
                        syncTgAttachmentPickerMenu();
                        setStatus(
                            `舌诊附件加载失败：${getErrorMessage(error)}`,
                        );
                    } finally {
                        sendBtn.disabled = false;
                        inputEl.focus();
                    }
                });
                attachmentTgPickerTriggerEl?.addEventListener("click", () => {
                    void (async () => {
                        try {
                            await fetchTgAttachmentList();
                        } catch (error) {
                            setStatus(
                                `读取舌诊附件列表失败：${getErrorMessage(error)}`,
                            );
                        }
                    })();
                });

                formEl.addEventListener("submit", async (event) => {
                    event.preventDefault();
                    const message = inputEl.value.trim();
                    if (!message) {
                        return;
                    }
                    if (!apiEndpoint) {
                        setStatus("请先在 api.json 中填写 apiEndpoint。");
                        return;
                    }

                    await ensureLocalOllamaModelReady();

                    appendMessage("user", message);
                    chatHistory.push({ role: "user", content: message });
                    inputEl.value = "";
                    autoResizeInput();
                    sendBtn.disabled = true;
                    setStatus("AI 思考中...");

                    try {
                        const messages: Array<{
                            role: "system" | "user" | "assistant";
                            content: string;
                        }> = [];

                        if (systemPrompt) {
                            messages.push({
                                role: "system",
                                content: systemPrompt.trim(),
                            });
                        }

                        const requestHistory = chatHistory.map((item) => ({
                            role: item.role,
                            content: item.content,
                        }));

                        if (selectedFacePrompt) {
                            for (
                                let index = requestHistory.length - 1;
                                index >= 0;
                                index -= 1
                            ) {
                                const item = requestHistory[index];
                                if (item.role === "user") {
                                    item.content = `${item.content}\n\n【面诊附件数据（${selectedFaceAttachmentName || "未命名"}）】\n${selectedFacePrompt}`;
                                    break;
                                }
                            }
                        }

                        if (selectedTgPrompt) {
                            for (
                                let index = requestHistory.length - 1;
                                index >= 0;
                                index -= 1
                            ) {
                                const item = requestHistory[index];
                                if (item.role === "user") {
                                    item.content = `${item.content}\n\n【舌诊附件数据（${selectedTgAttachmentName || "未命名"}）】\n${selectedTgPrompt}`;
                                    break;
                                }
                            }
                        }

                        messages.push(...requestHistory);

                        const response = await fetch(chatProxyUrl, {
                            method: "POST",
                            headers: {
                                "Content-Type": "application/json",
                            },
                            credentials: "include",
                            body: JSON.stringify({
                                selectedOptionName,
                                messages,
                                stream: useStream,
                                temperature: currentTemperature,
                            }),
                        });

                        if (!response.ok) {
                            const errorText = await response.text();
                            const detail = errorText.trim();
                            const isProxyNotFound =
                                response.status === 404 &&
                                detail.includes("Path: /project/chat");
                            if (isProxyNotFound) {
                                throw new Error(
                                    "本地代理路由 /project/chat 不可用。请通过 `npm run dev` 或 `npm run preview` 启动 Astro，并访问终端显示的正确端口。",
                                );
                            }
                            throw new Error(
                                `请求失败：HTTP ${response.status}${detail ? ` - ${detail}` : ""}`,
                            );
                        }

                        const contentType =
                            response.headers.get("content-type") || "";
                        const resolvedModelHeader =
                            response.headers.get("x-resolved-model") || "";
                        let aiReply = "";
                        if (useStream) {
                            const aiBubble = appendMessage("ai", "");
                            aiReply = await readPlainTextStream(
                                response,
                                aiBubble,
                            );
                        } else {
                            const payload = contentType.includes(
                                "application/json",
                            )
                                ? await response.json()
                                : await response.text();
                            aiReply = parseReply(payload);
                            appendMessage("ai", aiReply);
                        }

                        if (!aiReply.trim()) {
                            aiReply = "（空响应）";
                        }
                        chatHistory.push({
                            role: "assistant",
                            content: aiReply,
                        });
                        const statusBase =
                            resolvedModelHeader && resolvedModelHeader !== model
                                ? `请求成功（实际模型：${resolvedModelHeader}）。`
                                : "请求成功。";
                        if (
                            resolvedModelHeader &&
                            resolvedModelHeader !== model
                        ) {
                            model = resolvedModelHeader;
                        }

                        try {
                            const savedRecord = await saveConversationRecord();
                            if (savedRecord) {
                                setStatus(
                                    `${statusBase} 已保存到记录：${savedRecord}。继续提问吧。`,
                                );
                            } else {
                                setStatus(`${statusBase} 继续提问吧。`);
                            }
                        } catch (saveError) {
                            setStatus(
                                `${statusBase} 但保存记录失败：${getErrorMessage(saveError)}`,
                            );
                        }
                    } catch (error) {
                        const errorMessage = getErrorMessage(error);
                        const notFoundModel =
                            extractModelNotFound(errorMessage);
                        let aiMessage = "";
                        if (notFoundModel) {
                            aiMessage = `模型 ${notFoundModel} 不存在，请先执行：ollama pull ${notFoundModel}`;
                        } else {
                            aiMessage = `请求出错：${errorMessage}`;
                        }
                        appendMessage("ai", aiMessage);
                        chatHistory.push({
                            role: "assistant",
                            content: aiMessage,
                        });
                        try {
                            await saveConversationRecord();
                        } catch {}
                        setStatus(
                            "请求失败，请检查模型是否已安装、接口地址或跨域设置。",
                        );
                    } finally {
                        sendBtn.disabled = false;
                        inputEl.focus();
                    }
                });

                renderHistoryOptions();
                void (async () => {
                    await loadApiConfig();
                    try {
                        await fetchRecordList();
                        await fetchFaceAttachmentList();
                        await fetchTgAttachmentList();
                    } catch (error) {
                        setStatus(
                            `读取历史记录失败：${getErrorMessage(error)}`,
                        );
                    }
                    autoResizeInput();
                })();
            } else {
                console.error("项目页初始化失败：缺少必要 DOM 节点。");
            }
        </script>
    </body>
</html>
