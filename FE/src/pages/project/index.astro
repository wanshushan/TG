            function setupPickerMenu(args: {
                rootEl: HTMLElement | null;
                selectEl: HTMLSelectElement | null;
                triggerEl: HTMLButtonElement | null;
                labelEl: HTMLSpanElement | null;
                panelEl: HTMLDivElement | null;
                optionsEl: HTMLDivElement | null;
                emptyLabel: string;
            }): () => void {
                const {
                    rootEl,
                    selectEl,
                    triggerEl,
                    labelEl,
                    panelEl,
                    optionsEl,
                    emptyLabel,
                } = args;

                if (
                    !rootEl ||
                    !selectEl ||
                    !triggerEl ||
                    !labelEl ||
                    !panelEl ||
                    !optionsEl
                ) {
                    return () => {};
                }

                const closePanel = () => {
                    panelEl.classList.remove("is-open");
                    triggerEl.setAttribute("aria-expanded", "false");
                    panelEl.style.transform = "translateX(0)";
                };

                const adjustPanelPosition = () => {
                    panelEl.style.transform = "translateX(0)";
                    const viewportGap = 8;
                    const rect = panelEl.getBoundingClientRect();
                    let offsetX = 0;

                    if (rect.right > window.innerWidth - viewportGap) {
                        offsetX = window.innerWidth - viewportGap - rect.right;
                    }
                    if (rect.left + offsetX < viewportGap) {
                        offsetX += viewportGap - (rect.left + offsetX);
                    }

                    if (offsetX !== 0) {
                        panelEl.style.transform = `translateX(${offsetX}px)`;
                    }
                };

                const renderOptions = () => {
                    const selectOptions = Array.from(selectEl.options);
                    const selectedOption =
                        selectOptions.find(
                            (option) => option.value === selectEl.value,
                        ) || selectOptions[0];

                    labelEl.textContent =
                        selectedOption?.textContent?.trim() || emptyLabel;
                    optionsEl.innerHTML = "";

                    for (const option of selectOptions) {
                        const optionButton = document.createElement("button");
                        optionButton.type = "button";
                        optionButton.className = "picker-option";
                        optionButton.textContent = option.textContent || "";
                        optionButton.setAttribute("role", "option");
                        const isSelected = option.value === selectEl.value;
                        optionButton.setAttribute(
                            "aria-selected",
                            isSelected ? "true" : "false",
                        );

                        if (isSelected) {
                            optionButton.classList.add("is-selected");
                        }

                        optionButton.addEventListener("click", () => {
                            if (selectEl.value !== option.value) {
                                selectEl.value = option.value;
                                selectEl.dispatchEvent(new Event("change"));
                            }
                            closePanel();
                        });

                        optionsEl.appendChild(optionButton);
                    }
                };

                if (rootEl.dataset.pickerInitialized !== "true") {
                    triggerEl.addEventListener("click", (event) => {
                        event.stopPropagation();
                        const nextOpen = !panelEl.classList.contains("is-open");
                        panelEl.classList.toggle("is-open", nextOpen);
                        triggerEl.setAttribute(
                            "aria-expanded",
                            nextOpen ? "true" : "false",
                        );

                        if (nextOpen) {
                            requestAnimationFrame(adjustPanelPosition);
                        }
                    });

                    document.addEventListener("click", (event) => {
                        const target = event.target;
                        if (!(target instanceof Node)) {
                            return;
                        }
                        if (!rootEl.contains(target)) {
                            closePanel();
                        }
                    });

                    document.addEventListener("keydown", (event) => {
                        if (event.key === "Escape") {
                            closePanel();
                        }
                    });

                    window.addEventListener("resize", () => {
                        if (panelEl.classList.contains("is-open")) {
                            adjustPanelPosition();
                        }
                    });

                    selectEl.addEventListener("change", renderOptions);
                    rootEl.dataset.pickerInitialized = "true";
                }

                renderOptions();
                return renderOptions;
            }

