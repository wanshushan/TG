---
import { FOOTER_SOCIAL_LINKS } from "../config";
import fa6BrandsIcons from "@iconify-json/fa6-brands/icons.json";
import fa6SolidIcons from "@iconify-json/fa6-solid/icons.json";
import fa6RegularIcons from "@iconify-json/fa6-regular/icons.json";

const today = new Date();

type IconData = {
	body: string;
	width?: number;
	height?: number;
	left?: number;
	top?: number;
};

type IconSet = {
	icons: Record<string, IconData>;
	width?: number;
	height?: number;
};

const brandIconSet = fa6BrandsIcons as IconSet;
const solidIconSet = fa6SolidIcons as IconSet;
const regularIconSet = fa6RegularIcons as IconSet;

function resolveIcon(iconName: string) {
	const match = iconName.match(/^(fa6-brands|fa6-solid|fa6-regular):(.+)$/);
	if (!match) {
		return null;
	}

	const [_, prefix, iconKey] = match;
	const iconSet =
		prefix === "fa6-brands"
			? brandIconSet
			: prefix === "fa6-solid"
				? solidIconSet
				: regularIconSet;

	const icon = iconSet.icons[iconKey];
	if (!icon) {
		return null;
	}

	const left = icon.left ?? 0;
	const top = icon.top ?? 0;
	const width = icon.width ?? iconSet.width ?? 512;
	const height = icon.height ?? iconSet.height ?? 512;

	return {
		body: icon.body,
		viewBox: `${left} ${top} ${width} ${height}`,
	};
}
---

<footer>
	&copy; {today.getFullYear()} wanshushan. All rights reserved.
	<div class="social-links">
		{
			FOOTER_SOCIAL_LINKS.map((link) => {
				const icon = resolveIcon(link.icon);
				return (
					<a
						href={link.href}
						target="_blank"
						rel="noopener noreferrer"
						aria-label={link.name}
						title={link.name}
					>
						<span class="sr-only">{link.name}</span>
						{icon ? (
							<svg
								viewBox={icon.viewBox}
								aria-hidden="true"
								width="32"
								height="32"
							>
								<g set:html={icon.body} />
							</svg>
						) : (
							<span class="icon-fallback" aria-hidden="true">
								{link.name}
							</span>
						)}
					</a>
				);
			})
		}
	</div>
</footer>
<style>
	footer {
		padding: 2em 1em 6em 1em;
		background: linear-gradient(var(--gray-gradient)) no-repeat;
		color: rgb(var(--gray));
		text-align: center;
	}
	.social-links {
		display: flex;
		justify-content: center;
		gap: 1em;
		margin-top: 1em;
	}
	.social-links a {
		text-decoration: none;
		color: rgb(var(--gray));
		display: inline-flex;
		align-items: center;
		justify-content: center;
	}
	.social-links a:hover {
		color: rgb(var(--gray-dark));
	}
	.icon-fallback {
		font-size: 0.8rem;
	}
</style>
