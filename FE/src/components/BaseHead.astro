---
// Import the global.css file here so that it is included on
// all pages through the use of the <BaseHead /> component.
import '../styles/global.css';
import 'overlayscrollbars/styles/overlayscrollbars.css';
import type { ImageMetadata } from 'astro';
import FallbackImage from '../assets/blog-placeholder-1.jpg';
import { getScrollbarConfig, siteConfig } from '../config';

interface Props {
	title?: string;
	description?: string;
	image?: ImageMetadata;
}

const canonicalURL = new URL(Astro.url.pathname, Astro.site);

const { title = siteConfig.title, description = siteConfig.description, image = FallbackImage } = Astro.props;
const scrollbarConfig = getScrollbarConfig();
const themeColorMatch = siteConfig.themeColor.match(
	/rgb\s*\(\s*(\d{1,3})\s*,\s*(\d{1,3})\s*,\s*(\d{1,3})\s*\)/i,
);
const themeColorChannels = themeColorMatch
	? `${themeColorMatch[1]}, ${themeColorMatch[2]}, ${themeColorMatch[3]}`
	: '35, 55, 255';

const resolvedFavicon = (() => {
	const raw = siteConfig.favicon?.trim();
	if (!raw) {
		return '/favicon.ico';
	}

	const normalized = raw.replace(/\\/g, '/');
	const stripped = normalized
		.replace(/^\.?\/?FE\/public\//i, '/')
		.replace(/^\.?\/?public\//i, '/');

	if (/^https?:\/\//i.test(stripped)) {
		return stripped;
	}

	return stripped.startsWith('/') ? stripped : `/${stripped}`;
})();

const scrollbarConfigCss = `
:root {
	--global-scrollbar-size: ${scrollbarConfig.size};
	--global-scrollbar-color: ${scrollbarConfig.color};
	--accent: ${siteConfig.themeColor};
	--accent-rgb: ${themeColorChannels};
}
`;
---

<style is:inline>{scrollbarConfigCss}</style>

<!-- Global Metadata -->
<meta charset="utf-8" />
<meta name="viewport" content="width=device-width,initial-scale=1" />
<link rel="icon" href={resolvedFavicon} />
<link rel="sitemap" href="/sitemap-index.xml" />
<link
	rel="alternate"
	type="application/rss+xml"
	title={siteConfig.title}
	href={new URL('rss.xml', Astro.site)}
/>
<meta name="generator" content={Astro.generator} />
<meta name="theme-color" content={siteConfig.themeColor} />

<!-- Font preloads -->
<link rel="preload" href="/fonts/atkinson-regular.woff" as="font" type="font/woff" crossorigin />
<link rel="preload" href="/fonts/atkinson-bold.woff" as="font" type="font/woff" crossorigin />

<!-- Canonical URL -->
<link rel="canonical" href={canonicalURL} />

<!-- Primary Meta Tags -->
<title>{title}</title>
<meta name="title" content={title} />
<meta name="description" content={description} />

<!-- Open Graph / Facebook -->
<meta property="og:type" content="website" />
<meta property="og:url" content={Astro.url} />
<meta property="og:title" content={title} />
<meta property="og:description" content={description} />
<meta property="og:image" content={new URL(image.src, Astro.url)} />

<!-- Twitter -->
<meta property="twitter:card" content="summary_large_image" />
<meta property="twitter:url" content={Astro.url} />
<meta property="twitter:title" content={title} />
<meta property="twitter:description" content={description} />
<meta property="twitter:image" content={new URL(image.src, Astro.url)} />

<!-- OverlayScrollbars 自动初始化脚本 -->
<script is:inline>
	(async () => {
		const { OverlayScrollbars } = await import('overlayscrollbars');
		
		// 获取系统主题偏好
		function getCurrentTheme() {
			return window.matchMedia('(prefers-color-scheme: dark)').matches ? 'dark' : 'light';
		}

		// 初始化带有 data-overlayscrollbars-initialize 属性的元素
		function reinitializeScrollbars() {
			const theme = getCurrentTheme();
			const themeClass = theme === 'dark' ? 'scrollbar-dark' : 'scrollbar-light';
			
			document.querySelectorAll('[data-overlayscrollbars-initialize]').forEach((element) => {
				// 移除旧的主题类
				element.classList.remove('scrollbar-auto', 'scrollbar-dark', 'scrollbar-light');
				// 添加新的主题类
				element.classList.add('scrollbar-auto');
				
				// 确保元素已初始化
				if (!OverlayScrollbars.valid(element)) {
					OverlayScrollbars(element, {
						scrollbars: {
							autoHide: 'move',
							autoHideDelay: 500,
						},
					});
				}
			});
		}

		// 页面加载完成后初始化
		if (document.readyState === 'loading') {
			document.addEventListener('DOMContentLoaded', reinitializeScrollbars);
		} else {
			reinitializeScrollbars();
		}

		// 页面导航时重新初始化
		document.addEventListener('astro:after-swap', reinitializeScrollbars);
		
		// 监听系统主题变化
		window.matchMedia('(prefers-color-scheme: dark)').addEventListener('change', reinitializeScrollbars);
	})();
</script>

