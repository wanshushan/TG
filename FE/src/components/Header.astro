---
import {
	siteConfig,
	getNavigationItems,
	HEADER_SOCIAL_LINKS,
	getAuthStateStorageKey,
	getAuthUsernameStorageKey,
	getUserBridgeEndpoint,
	getUserFallbackName,
	getUserPagePath,
} from "../config";
import HeaderLink from "./HeaderLink.astro";
import fa6BrandsIcons from "@iconify-json/fa6-brands/icons.json";
import fa6SolidIcons from "@iconify-json/fa6-solid/icons.json";
import fa6RegularIcons from "@iconify-json/fa6-regular/icons.json";

type IconData = {
	body: string;
	width?: number;
	height?: number;
	left?: number;
	top?: number;
};

type IconSet = {
	icons: Record<string, IconData>;
	width?: number;
	height?: number;
};

const brandIconSet = fa6BrandsIcons as IconSet;
const solidIconSet = fa6SolidIcons as IconSet;
const regularIconSet = fa6RegularIcons as IconSet;

function resolveIcon(iconName?: string) {
	if (!iconName) {
		return null;
	}

	const match = iconName.match(/^(fa6-brands|fa6-solid|fa6-regular):(.+)$/);
	if (!match) {
		return null;
	}

	const [_, prefix, iconKey] = match;
	const iconSet =
		prefix === "fa6-brands"
			? brandIconSet
			: prefix === "fa6-solid"
				? solidIconSet
				: regularIconSet;
	const icon = iconSet.icons[iconKey];

	if (!icon) {
		return null;
	}

	const left = icon.left ?? 0;
	const top = icon.top ?? 0;
	const width = icon.width ?? iconSet.width ?? 512;
	const height = icon.height ?? iconSet.height ?? 512;

	return {
		body: icon.body,
		viewBox: `${left} ${top} ${width} ${height}`,
	};
}

const headerUserBridgeEndpoint = getUserBridgeEndpoint();
const headerUserFallbackName = getUserFallbackName();
const headerUserPagePath = getUserPagePath();
const headerAuthStateStorageKey = getAuthStateStorageKey();
const headerAuthUsernameStorageKey = getAuthUsernameStorageKey();
const navigationItems = getNavigationItems();
---

<header>
	<nav>
		<h2><a href="/">{siteConfig.title}</a></h2>
		<div class="internal-links">
			{
				navigationItems.map((item) => {
					const icon = resolveIcon(item.icon);
					return (
						<HeaderLink href={item.href}>
							<span class="link-content">
								{icon && (
									<svg
										class="nav-icon-svg"
										viewBox={icon.viewBox}
										aria-hidden="true"
										width="16"
										height="16"
									>
										<g set:html={icon.body} />
									</svg>
								)}
								<span>{item.label}</span>
							</span>
						</HeaderLink>
					);
				})
			}
		</div>
		<div class="social-links">
			{
				HEADER_SOCIAL_LINKS.map((link) => {
					const icon = resolveIcon(link.icon);
					const isUserEntry = link.href === headerUserPagePath;
					const content = (
						<span class="link-content">
							{icon && (
								<svg
									class="social-icon-svg"
									viewBox={icon.viewBox}
									aria-hidden="true"
									width="16"
									height="16"
								>
									<g set:html={icon.body} />
								</svg>
							)}
							<span
								data-header-username={
									isUserEntry ? "true" : undefined
								}
							>
								{link.name}
							</span>
						</span>
					);

					if (link.external) {
						return (
							<a
								href={link.href}
								title={link.name}
								target="_blank"
								rel="noopener"
							>
								{content}
							</a>
						);
					}

					return (
						<HeaderLink href={link.href} title={link.name}>
							{content}
						</HeaderLink>
					);
				})
			}
		</div>
		<button
			type="button"
			class="mobile-menu-toggle"
			id="header-mobile-menu-toggle"
			aria-label="更多导航"
			aria-expanded="false"
			aria-controls="header-mobile-menu-panel"
		>
			<!-- <svg viewBox="0 0 24 24" width="20" height="20" aria-hidden="true">
				<circle cx="12" cy="5" r="2"></circle>
				<circle cx="12" cy="12" r="2"></circle>
				<circle cx="12" cy="19" r="2"></circle>
			</svg> -->
			<svg
				xmlns="http://www.w3.org/2000/svg"
				width="24"
				height="24"
				viewBox="0 0 448 512"
				><!-- Icon from Font Awesome 6 Solid by Dave Gandy - https://creativecommons.org/licenses/by/4.0/ -->
				<path
					fill="currentColor"
					d="M0 96c0-17.7 14.3-32 32-32h384c17.7 0 32 14.3 32 32s-14.3 32-32 32H32c-17.7 0-32-14.3-32-32m0 160c0-17.7 14.3-32 32-32h384c17.7 0 32 14.3 32 32s-14.3 32-32 32H32c-17.7 0-32-14.3-32-32m448 160c0 17.7-14.3 32-32 32H32c-17.7 0-32-14.3-32-32s14.3-32 32-32h384c17.7 0 32 14.3 32 32"
				></path></svg
			>
		</button>
		<div
			class="mobile-menu-panel"
			id="header-mobile-menu-panel"
			aria-hidden="true"
		>
			<div class="mobile-menu-group">
				{
					navigationItems.map((item) => {
						const icon = resolveIcon(item.icon);
						return (
							<HeaderLink href={item.href}>
								<span class="link-content">
									{icon && (
										<svg
											class="nav-icon-svg"
											viewBox={icon.viewBox}
											aria-hidden="true"
											width="16"
											height="16"
										>
											<g set:html={icon.body} />
										</svg>
									)}
									<span>{item.label}</span>
								</span>
							</HeaderLink>
						);
					})
				}
			</div>
			<div class="mobile-menu-group">
				{
					HEADER_SOCIAL_LINKS.map((link) => {
						const icon = resolveIcon(link.icon);
						const isUserEntry = link.href === headerUserPagePath;
						const content = (
							<span class="link-content">
								{icon && (
									<svg
										class="social-icon-svg"
										viewBox={icon.viewBox}
										aria-hidden="true"
										width="16"
										height="16"
									>
										<g set:html={icon.body} />
									</svg>
								)}
								<span
									data-header-username={
										isUserEntry ? "true" : undefined
									}
								>
									{link.name}
								</span>
							</span>
						);

						if (link.external) {
							return (
								<a
									href={link.href}
									title={link.name}
									target="_blank"
									rel="noopener"
								>
									{content}
								</a>
							);
						}

						return (
							<HeaderLink href={link.href} title={link.name}>
								{content}
							</HeaderLink>
						);
					})
				}
			</div>
		</div>
	</nav>
</header>
<script
	define:vars={{
		headerUserBridgeEndpoint,
		headerUserFallbackName,
		headerAuthStateStorageKey,
		headerAuthUsernameStorageKey,
	}}
>
	function normalizeText(value) {
		return typeof value === "string" ? value.trim() : "";
	}

	function persistAuthState(loggedIn, username) {
		try {
			window.localStorage.setItem(
				headerAuthStateStorageKey,
				loggedIn ? "true" : "false",
			);

			if (loggedIn && username) {
				window.localStorage.setItem(
					headerAuthUsernameStorageKey,
					username,
				);
			} else {
				window.localStorage.removeItem(headerAuthUsernameStorageKey);
			}
		} catch {
			// 忽略存储异常，避免影响主流程
		}
	}

	async function syncHeaderUsername() {
		try {
			const response = await fetch(headerUserBridgeEndpoint, {
				cache: "no-store",
			});
			if (!response.ok) {
				return;
			}

			const payload = await response.json();
			const isLoggedIn = payload?.isLoggedIn === true;
			const username =
				normalizeText(payload?.username) || headerUserFallbackName;
			persistAuthState(isLoggedIn, isLoggedIn ? username : "");

			document
				.querySelectorAll("[data-header-username='true']")
				.forEach((node) => {
					node.textContent = username;

					const link = node.closest("a");
					if (link) {
						link.setAttribute("title", username);
					}
				});
		} catch {
			// 保持 fallback 文本，不额外抛错
		}
	}

	function setupHeaderMobileMenu() {
		const menuToggle = document.getElementById("header-mobile-menu-toggle");
		const menuPanel = document.getElementById("header-mobile-menu-panel");

		if (!(menuToggle instanceof HTMLButtonElement) || !menuPanel) {
			return;
		}

		if (menuToggle.dataset.initialized === "true") {
			return;
		}

		const closeMenu = () => {
			menuPanel.classList.remove("is-open");
			menuPanel.setAttribute("aria-hidden", "true");
			menuToggle.setAttribute("aria-expanded", "false");
		};

		const toggleMenu = () => {
			const isOpen = menuPanel.classList.toggle("is-open");
			menuPanel.setAttribute("aria-hidden", isOpen ? "false" : "true");
			menuToggle.setAttribute("aria-expanded", isOpen ? "true" : "false");
		};

		menuToggle.addEventListener("click", (event) => {
			event.stopPropagation();
			toggleMenu();
		});

		document.addEventListener("click", (event) => {
			const target = event.target;
			if (!(target instanceof Node)) {
				return;
			}

			if (!menuPanel.contains(target) && !menuToggle.contains(target)) {
				closeMenu();
			}
		});

		document.addEventListener("keydown", (event) => {
			if (event.key === "Escape") {
				closeMenu();
			}
		});

		menuPanel.querySelectorAll("a").forEach((linkNode) => {
			linkNode.addEventListener("click", closeMenu);
		});

		window.addEventListener("resize", () => {
			if (window.innerWidth > 720) {
				closeMenu();
			}
		});

		menuToggle.dataset.initialized = "true";
	}

	function initHeaderInteractions() {
		syncHeaderUsername();
		setupHeaderMobileMenu();
	}

	if (document.readyState === "loading") {
		document.addEventListener("DOMContentLoaded", initHeaderInteractions);
	} else {
		initHeaderInteractions();
	}

	document.addEventListener("astro:after-swap", initHeaderInteractions);
</script>
<style>
	header {
		margin: 0;
		padding: 0 1em;
		background: white;
		box-shadow: 0 2px 8px rgba(var(--black), 5%);
	}
	h2 {
		margin: 0;
		font-size: 1em;
	}

	h2 a,
	h2 a.active {
		text-decoration: none;
	}
	nav {
		display: flex;
		align-items: center;
		justify-content: space-between;
		position: relative;
	}
	nav a {
		padding: 1em 0.5em;
		color: var(--black);
		border-bottom: 4px solid transparent;
		text-decoration: none;
	}
	nav a.active {
		text-decoration: none;
		border-bottom-color: var(--accent);
	}
	.social-links,
	.social-links a {
		display: flex;
	}
	.mobile-menu-toggle {
		display: none;
		align-items: center;
		justify-content: center;
		width: 2.75rem;
		height: 2.75rem;
		border: 0;
		border-radius: 0.7rem;
		background: transparent;
		color: rgb(var(--black));
		cursor: pointer;
		transition: background-color 0.2s ease;
	}
	.mobile-menu-toggle:hover {
		background: rgba(var(--gray-light), 0.85);
	}
	.mobile-menu-toggle:active {
		background: rgba(var(--gray-light), 1);
	}
	.mobile-menu-toggle svg {
		fill: currentColor;
	}
	.mobile-menu-panel {
		display: none;
		position: absolute;
		right: 0;
		top: calc(100% + 0.4rem);
		z-index: 30;
		width: min(18rem, calc(100vw - 2rem));
		padding: 0.45rem;
		background: white;
		border-radius: 0.8rem;
		box-shadow: 0 10px 24px rgba(var(--black), 12%);
	}
	.mobile-menu-panel.is-open {
		display: block;
	}
	.mobile-menu-group {
		display: flex;
		flex-direction: column;
		gap: 0.1rem;
	}
	.mobile-menu-group + .mobile-menu-group {
		margin-top: 0.3rem;
		padding-top: 0.35rem;
		border-top: 1px solid rgba(var(--gray), 20%);
	}
	.mobile-menu-panel a {
		display: block;
		padding: 0.75rem 0.65rem;
		border-bottom: 0;
		border-radius: 0.55rem;
	}
	.mobile-menu-panel a:hover {
		background: rgba(var(--gray-light), 0.6);
	}
	.mobile-menu-panel a.active {
		border-bottom-color: transparent;
		background: rgba(var(--accent-rgb), 0.1);
	}
	.link-content {
		display: inline-flex;
		align-items: center;
		gap: 0.35rem;
	}
	.nav-icon-svg,
	.social-icon-svg {
		fill: currentColor;
		flex-shrink: 0;
	}
	@media (max-width: 720px) {
		.internal-links,
		.social-links {
			display: none;
		}
		.mobile-menu-toggle {
			display: inline-flex;
		}
	}
</style>
